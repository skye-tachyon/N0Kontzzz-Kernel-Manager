    <!-- Tuning Feature Info Dialog strings -->
    <string name="tuning_feature_info_title">Informasi Fitur Tuning</string>
    <string name="tuning_feature_performance_mode_title">Mode Performa</string>
    <string name="tuning_feature_performance_mode_desc">Menyediakan preset konfigurasi untuk mengoptimalkan sistem sesuai kebutuhan: Seimbang (schedutil governor) dan Performa (performance governor).</string>
    <string name="tuning_feature_cpu_governor_title">Governor CPU</string>
    <string name="tuning_feature_cpu_governor_desc">Mengontrol bagaimana frekuensi CPU naik turun berdasarkan beban kerja. Berbagai governor dapat memengaruhi performa dan konsumsi daya.</string>
    <string name="tuning_feature_gpu_control_title">Kontrol GPU</string>
    <string name="tuning_feature_gpu_control_desc">Mengatur berbagai parameter terkait GPU seperti frekuensi maksimum, governor GPU, dan lainnya untuk mengoptimalisasi performa grafis atau efisiensi daya.</string>
    <string name="tuning_feature_thermal_title">Termal</string>
    <string name="tuning_feature_thermal_desc">Mengelola batas suhu perangkat. Penyesuaian di sini dapat mencegah throttling (penurunan performa karena panas berlebih) atau sebaliknya mengizinkan performa lebih tinggi dengan risiko suhu lebih panas.</string>
    <string name="tuning_feature_swappiness_title">Swappiness</string>
    <string name="tuning_feature_swappiness_desc">Mengontrol seberapa agresif kernel memindahkan data dari RAM ke zRAM/swap. Nilai tinggi berarti swapping lebih agresif (menghemat RAM aktif tapi lebih lambat), nilai rendah mempertahankan data di RAM lebih lama.</string>

    <string name="kernel_verification_title">Kernel Tidak Didukung</string>
    <string name="kernel_verification_desc">Aplikasi ini hanya mendukung N0Kontzzz, N0kernel, Lunar, FusionX, E404R, perf+, dan Oxygen+.</string>
    <string name="kernel_verification_perf_note">Untuk \'perf+\', hanya build dari \'rohmanurip@Github\' yang didukung. Untuk \'Oxygen+\', hanya build dari \'danda@pavilion\' yang didukung. Untuk \'N0kernel\', hanya build dari \'Impqxr@github.com\' yang didukung.</string>
    <string name="kernel_verification_instruction">Harap gunakan kernel yang didukung untuk melanjutkan.</string>
    <string name="root_required">Root Diperlukan</string>
    <string name="root_required_desc">Aplikasi ini memerlukan akses root agar berfungsi dengan baik. Harap berikan izin root.</string>
    <string name="exit_app">Keluar</string>

